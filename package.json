{
  "name": "scribe-agent-engine",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "cli": "npm run build && npx @google/adk-devtools run dist/index.js",
    "web": "npm run build && npx @google/adk-devtools web --port 8000 --allow_origins=* dist/index.js",
    "start": "npm run build && node dist/index.js",
    "mcp": "npm run build && node dist/mcp-server.js",
    "mcp:http": "npm run build && node dist/mcp-server.js http"
  },
  "dependencies": {
    "@google/adk": "^1.2.0",
    "@google/genai": "^1.37.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "body-parser": "^1.20.3",
    "convex": "^1.31.5",
    "cors": "^2.8.5",
    "docx": "^9.5.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "image-size": "^2.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@google/adk-devtools": "^1.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  }
}
